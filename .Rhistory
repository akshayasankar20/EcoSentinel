alpha=0.05
n1=32
n2=36
x1=72
x2=70
s1=8
s2=6
print("H0:= x1=x2")
print("H1 := x1!=x2")
ztab=qnorm(1-alpha)
zcal=(x1-x2)/sqrt((s1^2)/n1)+((s2^2)/n2)
if(abs(zcal)<abs(ztab)) {                              print("H0 is accepted")                                } else {                                               print("H0 is rejected")                                }
ztab
zcal
