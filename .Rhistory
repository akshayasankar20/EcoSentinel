alpha <- 0.05
P <- 20/100      # Hypothesized proportion = 0.20
p <- 50/400      # Sample proportion = 0.125
n <- 400
print("Ho:= p = P")
print("H1:= p != P")
ztab <- qnorm(1 - alpha/2)
zcal <- (p - P) / sqrt(P * (1 - P) / n)
if (abs(zcal) < abs(ztab)) {
print("Ho is accepted")
} else {
print("Ho is rejected")
}
