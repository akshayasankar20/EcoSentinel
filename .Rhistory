alpha=0.01
n1=1000
n2=1200
p1=800/1000
p2=800/1200
print("H0:= p1=p2")
print("H1 := p1!=p2")
ztab=qnorm(1-alpha)
P=((n1*p1)+(n2*p2))/(n1+n2)
zcal=(p1-p2)/sqrt(P*(1-P)*((1/n1)+(1/n2)))
if(abs(zcal)<abs(ztab)){                               print("H0 is accepted")                                }else{                                                 print("H1 is rejected")                                }
zcal
ztab
